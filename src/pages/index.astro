---
import Layout from "../layouts/Layout.astro";
import ToolCard from "../components/ToolCard.astro";

const base64Icon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" /></svg>`;
const jsonIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>`;
const jwtIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H5v-2H3v-2H1v-4a6 6 0 017.743-5.743z" /></svg>`;
const shieldIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 20.944a11.955 11.955 0 0118 0z" /></svg>`;
const clockIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
const binaryIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20v-6m0 0V4m0 6h4m-4 0H6m4 0v6m0-6V4m0 6h4m-4 0H6" /></svg>`;
const fingerprintIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0012 11c1.23 0 2.418.07 3.566.203m-11.82 4.242A21.88 21.88 0 0012 11c-1.23 0-2.418-.07-3.566-.203M12 11c0-3.517 1.009-6.799 2.753-9.571m3.44 2.04l-.054.09A13.916 13.916 0 0016 11a4 4 0 11-8 0c0-1.017.07-2.019.203-3m2.118-6.844A21.88 21.88 0 0012 11c-1.23 0-2.418-.07-3.566-.203" /></svg>`;
const markdownIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>`;
const textIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" /></svg>`;
const urlIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 00(5.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>`;
const aiIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`;
const sshIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H5v-2H3v-2H1v-4a6 6 0 017.743-5.743z" /></svg>`;
const convertIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>`;

const tools = [
    {
        title: "Conversor de Archivos",
        description: "Convierte entre diferentes formatos de archivos de forma rápida y segura.",
        href: "https://converter.devcito.org",
        icon: convertIcon,
        isNew: true,
    },
    {
        title: "Generador de Llaves SSH",
        description: "Genera pares de llaves RSA para SSH usando entropía real del movimiento de tu mouse.",
        href: "/tools/ssh-keygen",
        icon: sshIcon,
        isNew: true,
    },
    {
        title: "Codificador / Decodificador Base64",
        description: "Codifica y decodifica texto fácilmente al formato Base64.",
        href: "/tools/base64",
    },
    {
        title: "Reescritor de Texto con IA",
        description: "Mejora o reformula textos utilizando un prompt personalizado.",
        href: "/tools/ai-rewriter",
        icon: aiIcon,
    },
    {
        title: "Formateador y Validador JSON",
        description: "Embellece, minifica y valida la sintaxis de código JSON.",
        href: "/tools/json-formatter",
    },
    {
        title: "Decodificador de JWT",
        description: "Inspecciona el contenido de tokens de autenticación (JWT).",
        href: "/tools/jwt-decoder",
        icon: jwtIcon,
    },
    {
        title: "Verificador de Firma HMAC",
        description: "Valida una firma HMAC-SHA256 con una clave secreta.",
        href: "/tools/hmac-verifier",
        icon: shieldIcon,
    },
    {
        title: "Conversor de Timestamp",
        description: "Convierte entre fechas legibles y timestamps de Unix.",
        href: "/tools/timestamp-converter",
        icon: clockIcon,
    },
    {
        title: "Conversor a Array de Bytes",
        description: "Convierte una cadena de texto a su array de bytes (Hex, Dec, Bin).",
        href: "/tools/bytes-converter",
        icon: binaryIcon,
    },
    {
        title: "Generador de Hashes (SHA)",
        description: "Calcula la huella digital de un texto con algoritmos seguros.",
        href: "/tools/hash-generator",
        icon: fingerprintIcon,
    },
    {
        title: "Previsualizador de Markdown",
        description: "Escribe Markdown y ve el resultado en HTML en tiempo real.",
        href: "/tools/markdown-previewer",
        icon: markdownIcon,
    },
    {
        title: "Contador de Texto",
        description: "Cuenta caracteres, palabras, líneas y tamaño en bytes.",
        href: "/tools/text-counter",
        icon: textIcon,
    },
    {
        title: "Codificador / Decodificador URL",
        description: "Codifica y decodifica texto para que sea seguro en URLs.",
        href: "/tools/url-encoder",
        icon: urlIcon,
    },
];
---

<Layout
    title="Devcito Utils | Premium Developer Tools"
    description="Una colección de herramientas premium gratuitas para desarrolladores: conversor Base64, formateador JSON, decodificador JWT y más."
>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.05); }
  }
  .animate-float { animation: float 10s ease-in-out infinite; }
  
  .grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3 Jacques 3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.03;
  }

  .shimmer-text {
    background: linear-gradient(
      to right,
      #3b82f6 20%,
      #06b6d4 30%,
      #8b5cf6 70%,
      #3b82f6 80%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-fill-color: transparent;
    background-size: 200% auto;
    animation: textShimmer 4s linear infinite;
  }

  @keyframes textShimmer {
    to { background-position: 200% center; }
  }

  .tools-grid > * {
    opacity: 0;
    animation: card-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes card-in {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .grid-stagger > *:nth-child(1)  { animation-delay: 0.1s; }
  .grid-stagger > *:nth-child(2)  { animation-delay: 0.15s; }
  .grid-stagger > *:nth-child(3)  { animation-delay: 0.2s; }
  .grid-stagger > *:nth-child(4)  { animation-delay: 0.25s; }
  .grid-stagger > *:nth-child(5)  { animation-delay: 0.3s; }
  .grid-stagger > *:nth-child(6)  { animation-delay: 0.35s; }
  .grid-stagger > *:nth-child(7)  { animation-delay: 0.4s; }
  .grid-stagger > *:nth-child(8)  { animation-delay: 0.45s; }
  .grid-stagger > *:nth-child(9)  { animation-delay: 0.5s; }
  .grid-stagger > *:nth-child(10) { animation-delay: 0.55s; }
  .grid-stagger > *:nth-child(11) { animation-delay: 0.6s; }
  .grid-stagger > *:nth-child(12) { animation-delay: 0.65s; }
  .grid-stagger > *:nth-child(13) { animation-delay: 0.7s; }
</style>

<main class="relative min-h-screen">
  <!-- Texture Overlay -->
  <div class="grain fixed inset-0 pointer-events-none z-50"></div>

  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-bold tracking-[0.2em] uppercase mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
          </span>
          Pro Developer Utilities
        </div>
        
        <h1 class="text-7xl md:text-9xl font-black mb-8 tracking-tighter leading-none">
          <span class="shimmer-text">DevcitoUtils</span>
        </h1>
        
        <p class="max-w-2xl mx-auto text-xl text-gray-400 leading-relaxed font-medium mb-12">
          La navaja suiza para el desarrollo moderno. Herramientas <span class="text-white"> ultrarrápidas</span>, totalmente <span class="text-white">privadas</span> y con una interfaz de otro nivel.
        </p>

        <div class="flex flex-wrap justify-center gap-6 mb-16">
          <div class="px-6 py-3 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md">
            <span class="block text-2xl font-black text-white leading-none mb-1">{tools.length}</span>
            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Tools</span>
          </div>
          <div class="px-6 py-3 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md">
            <span class="block text-2xl font-black text-white leading-none mb-1">100%</span>
            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Client Side</span>
          </div>
          <div class="px-6 py-3 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md">
            <span class="block text-2xl font-black text-white leading-none mb-1">∞</span>
            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Privacy</span>
          </div>
        </div>

        <a href="#tools" class="group relative inline-flex items-center gap-3 px-10 py-5 bg-white text-black font-black rounded-2xl transition-all duration-300 hover:scale-105 active:scale-95 shadow-[0_0_30px_rgba(255,255,255,0.2)]">
          Comenzar a usar
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Floating Background Elements -->
    <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[120px] animate-float opacity-30 -z-10"></div>
    <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-cyan-600/10 rounded-full blur-[100px] animate-float opacity-30 -z-10" style="animation-delay: -5s"></div>
  </section>

  <!-- Tools Grid Section -->
  <section id="tools" class="py-24 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
        <div>
          <h2 class="text-4xl md:text-5xl font-black text-white tracking-tight mb-4">Catálogo de Herramientas</h2>
          <p class="text-gray-500 font-medium max-w-xl">
            Todo lo que necesitas en un solo lugar. Sin configuraciones, sin registros, solo utilidad pura.
          </p>
        </div>
        <div class="flex items-center gap-4 bg-white/5 border border-white/10 px-5 py-3 rounded-2xl backdrop-blur-md">
          <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
          <span class="text-sm font-bold text-gray-300">{tools.length} Herramientas Listas</span>
        </div>
      </div>

      <div class="tools-grid grid-stagger grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {tools.map((tool) => <ToolCard {...tool} />)}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-20 border-t border-white/5 relative overflow-hidden text-center">
    <div class="max-w-4xl mx-auto px-4 relative z-10">
      <p class="text-gray-400 leading-relaxed mb-10 max-w-lg mx-auto">
        Diseñado para la velocidad. Construido para la privacidad. <br/>
        Tus datos nunca salen de tu máquina.
      </p>
      <div class="flex items-center justify-center gap-8">
        <a href="https://devcito.org" target="_blank" class="text-sm font-bold text-gray-500 hover:text-white transition-colors uppercase tracking-widest">Website</a>
        <div class="w-1 h-1 rounded-full bg-gray-800"></div>
        <a href="https://github.com/devcito" target="_blank" class="text-sm font-bold text-gray-500 hover:text-white transition-colors uppercase tracking-widest">GitHub</a>
      </div>
      <p class="mt-8 text-sm text-gray-500 font-medium">
        Hecho con ❤️ por <a href="https://devcito.org" target="_blank" class="text-blue-400 hover:text-blue-300 transition-colors">Devcito</a>
      </p>
      <p class="mt-4 text-xs font-bold text-gray-700 uppercase tracking-widest">
        &copy; {new Date().getFullYear()} Devcito Utils. All rights reserved.
      </p>
    </div>
    
    <!-- Decorative -->
    <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-blue-600/5 rounded-full blur-[100px]"></div>
    <div class="absolute -bottom-20 -right-20 w-80 h-80 bg-cyan-600/5 rounded-full blur-[100px]"></div>
  </footer>
</main>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import ToolCard from "../components/ToolCard.astro";

const base64Icon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" /></svg>`;

const jsonIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>`;

const jwtIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H5v-2H3v-2H1v-4a6 6 0 017.743-5.743z" /></svg>`;

const shieldIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 20.944a11.955 11.955 0 0118 0z" /></svg>`;

const clockIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;

const binaryIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20v-6m0 0V4m0 6h4m-4 0H6m4 0v6m0-6V4m0 6h4m-4 0H6" /></svg>`;

const fingerprintIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0012 11c1.23 0 2.418.07 3.566.203m-11.82 4.242A21.88 21.88 0 0012 11c-1.23 0-2.418-.07-3.566-.203M12 11c0-3.517 1.009-6.799 2.753-9.571m3.44 2.04l-.054.09A13.916 13.916 0 0016 11a4 4 0 11-8 0c0-1.017.07-2.019.203-3m2.118-6.844A21.88 21.88 0 0012 11c-1.23 0-2.418-.07-3.566-.203" /></svg>`;

const markdownIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>`;

const textIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" /></svg>`;

const urlIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>`;

const aiIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>`;

const sshIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H5v-2H3v-2H1v-4a6 6 0 017.743-5.743z" /></svg>`;

const tools = [
    {
        title: "Generador de Llaves SSH",
        description: "Genera pares de llaves RSA para SSH usando entropía real del movimiento de tu mouse.",
        href: "/tools/ssh-keygen",
        icon: sshIcon,
        isNew: true,
    },
    {
        title: "Codificador / Decodificador Base64",
        description:
            "Codifica y decodifica texto fácilmente al formato Base64.",
        href: "/tools/base64",
    },
    {
        title: "Reescritor de Texto con IA",
        description:
            "Mejora o reformula textos utilizando un prompt personalizado.",
        href: "/tools/ai-rewriter",
        icon: aiIcon,
    },
    {
        title: "Formateador y Validador JSON",
        description: "Embellece, minifica y valida la sintaxis de código JSON.",
        href: "/tools/json-formatter",
    },
    {
        title: "Decodificador de JWT",
        description:
            "Inspecciona el contenido de tokens de autenticación (JWT).",
        href: "/tools/jwt-decoder",
        icon: jwtIcon,
    },
    {
        title: "Verificador de Firma HMAC",
        description: "Valida una firma HMAC-SHA256 con una clave secreta.",
        href: "/tools/hmac-verifier",
        icon: shieldIcon,
    },
    {
        title: "Conversor de Timestamp",
        description: "Convierte entre fechas legibles y timestamps de Unix.",
        href: "/tools/timestamp-converter",
        icon: clockIcon,
    },
    {
        title: "Conversor a Array de Bytes",
        description:
            "Convierte una cadena de texto a su array de bytes (Hex, Dec, Bin).",
        href: "/tools/bytes-converter",
        icon: binaryIcon,
    },
    {
        title: "Generador de Hashes (SHA)",
        description:
            "Calcula la huella digital de un texto con algoritmos seguros.",
        href: "/tools/hash-generator",
        icon: fingerprintIcon,
    },
    {
        title: "Previsualizador de Markdown",
        description:
            "Escribe Markdown y ve el resultado en HTML en tiempo real.",
        href: "/tools/markdown-previewer",
        icon: markdownIcon,
    },
    {
        title: "Contador de Texto",
        description: "Cuenta caracteres, palabras, líneas y tamaño en bytes.",
        href: "/tools/text-counter",
        icon: textIcon,
    },
    {
        title: "Codificador/Decodificador URL",
        description: "Codifica y decodifica texto para que sea seguro en URLs.",
        href: "/tools/url-encoder",
        icon: urlIcon,
    },
];
---

<Layout
    title="Devcito Utils | Herramientas Online para Desarrolladores"
    description="Una colección de herramientas online gratuitas para desarrolladores: conversor Base64, formateador JSON, decodificador JWT, generador de hashes y más."
>

<style>
  @keyframes float-slow {
    0%, 100% { transform: translateY(0px) scale(1); }
    50% { transform: translateY(-24px) scale(1.04); }
  }
  @keyframes float-med {
    0%, 100% { transform: translateY(0px) scale(1); }
    50% { transform: translateY(-16px) scale(1.02); }
  }
  .orb-1 { animation: float-slow 9s ease-in-out infinite; }
  .orb-2 { animation: float-med 7s ease-in-out infinite 1.5s; }
  .orb-3 { animation: float-slow 11s ease-in-out infinite 3s; }

  @keyframes shine {
    from { background-position: -200% center; }
    to   { background-position:  200% center; }
  }
  .shimmer-text {
    background: linear-gradient(90deg, #60a5fa, #34d399, #f59e0b, #f472b6, #60a5fa);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shine 5s linear infinite;
  }

  @keyframes card-in {
    from { opacity:0; transform: translateY(20px); }
    to   { opacity:1; transform: translateY(0); }
  }
  .tools-grid > * {
    opacity: 0;
    animation: card-in 0.4s ease forwards;
  }
  .tools-grid > *:nth-child(1)  { animation-delay: 0.05s; }
  .tools-grid > *:nth-child(2)  { animation-delay: 0.10s; }
  .tools-grid > *:nth-child(3)  { animation-delay: 0.15s; }
  .tools-grid > *:nth-child(4)  { animation-delay: 0.20s; }
  .tools-grid > *:nth-child(5)  { animation-delay: 0.25s; }
  .tools-grid > *:nth-child(6)  { animation-delay: 0.30s; }
  .tools-grid > *:nth-child(7)  { animation-delay: 0.35s; }
  .tools-grid > *:nth-child(8)  { animation-delay: 0.40s; }
  .tools-grid > *:nth-child(9)  { animation-delay: 0.45s; }
  .tools-grid > *:nth-child(10) { animation-delay: 0.50s; }
  .tools-grid > *:nth-child(11) { animation-delay: 0.55s; }
  .tools-grid > *:nth-child(12) { animation-delay: 0.60s; }
</style>

<main class="relative overflow-x-hidden">

  <!-- Ambient background orbs -->
  <div class="pointer-events-none fixed inset-0 overflow-hidden -z-10" aria-hidden="true">
    <div class="orb-1 absolute -top-32 -left-32 w-[520px] h-[520px] rounded-full opacity-[0.07]" style="background: radial-gradient(circle, #3b82f6 0%, transparent 70%);"></div>
    <div class="orb-2 absolute top-1/2 -right-48 w-[480px] h-[480px] rounded-full opacity-[0.06]" style="background: radial-gradient(circle, #06b6d4 0%, transparent 70%);"></div>
    <div class="orb-3 absolute -bottom-32 left-1/3 w-[400px] h-[400px] rounded-full opacity-[0.05]" style="background: radial-gradient(circle, #8b5cf6 0%, transparent 70%);"></div>
  </div>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section id="hero" class="min-h-[calc(100vh-4rem)] flex flex-col justify-center items-center text-center px-4 py-24">
    <div class="max-w-4xl">

      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-semibold px-4 py-1.5 rounded-full mb-6 tracking-widest uppercase">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
        Herramientas de desarrollo
      </div>

      <h1 class="text-6xl md:text-8xl font-black mb-6 tracking-tight leading-none">
        <span class="shimmer-text">DevcitoUtils</span>
      </h1>

      <p class="text-lg md:text-xl text-gray-400 mb-4 max-w-2xl mx-auto leading-relaxed">
        Una colección de herramientas gratuitas para desarrolladores.
        <br class="hidden md:block">
        <span class="text-gray-300">Rápidas, privadas y sin registro.</span>
      </p>

      <!-- Stats row -->
      <div class="flex items-center justify-center gap-8 mb-10 mt-8">
        <div class="text-center">
          <div class="text-2xl font-black text-white">{tools.length}</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Herramientas</div>
        </div>
        <div class="w-px h-8 bg-gray-800"></div>
        <div class="text-center">
          <div class="text-2xl font-black text-white">100%</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">En el cliente</div>
        </div>
        <div class="w-px h-8 bg-gray-800"></div>
        <div class="text-center">
          <div class="text-2xl font-black text-white">0</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Datos enviados</div>
        </div>
      </div>

      <a href="#tools"
        class="group inline-flex items-center gap-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold py-3.5 px-8 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-blue-900/50 hover:shadow-blue-700/60 text-sm">
        Explorar Herramientas
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </section>

  <!-- ── Tools Grid ─────────────────────────────────────────────────────────── -->
  <section id="tools" class="pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-10">
        <div>
          <p class="text-xs font-semibold text-blue-400 uppercase tracking-widest mb-2">Catálogo completo</p>
          <h2 class="text-3xl md:text-4xl font-black text-white">Herramientas disponibles</h2>
        </div>
        <span class="text-sm text-gray-600 font-mono bg-gray-800/60 px-3 py-1.5 rounded-lg border border-gray-700/60 self-start sm:self-auto">
          {tools.length} tools
        </span>
      </div>

      <!-- Grid -->
      <div class="tools-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {tools.map((tool) => <ToolCard {...tool} />)}
      </div>
    </div>
  </section>

  <!-- ── Footer / About ──────────────────────────────────────────────────────── -->
  <footer id="about" class="border-t border-gray-800/50 py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-gray-800/60 border border-gray-700/60 mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <h3 class="text-2xl font-black text-white mb-3">Acerca de Devcito Utils</h3>
      <p class="text-gray-400 max-w-xl mx-auto leading-relaxed">
        Un proyecto de acceso rápido que simplifica tareas comunes de desarrollo.
        Todo corre en el cliente — tus datos nunca salen de tu navegador.
      </p>
      <p class="text-gray-600 text-sm mt-6">
        Hecho con ❤️ por
        <a href="https://devcito.org" target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:text-blue-300 transition-colors">Devcito</a>.
      </p>
    </div>
  </footer>

</main>
</Layout>

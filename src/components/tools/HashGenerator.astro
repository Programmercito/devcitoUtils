---
// Hash Generator Component
---

<div class="max-w-4xl mx-auto">
    <div class="tool-panel space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
                <label for="hash-input" class="tool-label">Texto de Entrada</label>
                <textarea id="hash-input" rows="8" class="tool-textarea" placeholder="Escribe o pega aquí el texto...">seguridad-devcito-2024</textarea>
            </div>

            <div class="space-y-6">
                <div>
                    <label for="algo-select" class="tool-label">Algoritmo</label>
                    <select id="algo-select" class="tool-select">
                        <option value="SHA-256">SHA-256</option>
                        <option value="SHA-1">SHA-1</option>
                        <option value="SHA-512">SHA-512</option>
                    </select>
                </div>

                <div class="space-y-4">
                    <label for="hash-output" class="tool-label">Hash de Salida (Hex)</label>
                    <div class="relative">
                        <textarea id="hash-output" class="tool-textarea font-mono pr-12 text-blue-400" rows="4" readonly placeholder="El hash aparecerá aquí..."></textarea>
                        <button id="copy-btn" class="absolute top-4 right-4 text-gray-500 hover:text-blue-400 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Bar -->
        <div class="pt-6 border-t border-white/5 flex flex-wrap gap-4 justify-center">
            <button id="clear-btn" class="tool-btn tool-btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                Limpiar
            </button>
            <button id="rehash-btn" class="tool-btn tool-btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                Regenerar
            </button>
        </div>
    </div>
</div>

<script>
    const input = document.getElementById('hash-input') as HTMLTextAreaElement;
    const algoSelect = document.getElementById('algo-select') as HTMLSelectElement;
    const output = document.getElementById('hash-output') as HTMLTextAreaElement;
    const copyBtn = document.getElementById('copy-btn');
    const clearBtn = document.getElementById('clear-btn');
    const rehashBtn = document.getElementById('rehash-btn');

    async function generateHash() {
        const text = input.value;
        const algorithm = algoSelect.value;
        if (!text) { output.value = ''; return; }
        try {
            const encoder = new TextEncoder();
            const data = encoder.encode(text);
            const hashBuffer = await crypto.subtle.digest(algorithm, data);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
            output.value = hashHex;
        } catch (e) {
            output.value = 'Error al generar el hash.';
        }
    }

    input.addEventListener('input', generateHash);
    algoSelect.addEventListener('change', generateHash);
    rehashBtn?.addEventListener('click', generateHash);

    clearBtn?.addEventListener('click', () => {
        input.value = '';
        output.value = '';
        input.focus();
    });

    copyBtn?.addEventListener('click', () => {
        if (output.value) {
            navigator.clipboard.writeText(output.value).then(() => {
                const originalHTML = copyBtn.innerHTML;
                copyBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>`;
                setTimeout(() => { copyBtn.innerHTML = originalHTML; }, 2000);
            });
        }
    });

    generateHash();
</script>

---
// Text Counter Component
---

<div class="tool-panel max-w-4xl mx-auto space-y-5">
    <div>
        <label for="text-input" class="tool-label">Texto</label>
        <textarea id="text-input" rows="10" class="tool-textarea" placeholder="Escribe o pega tu texto aquí..."></textarea>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="tool-stat-card">
            <p class="tool-label mb-1">Caracteres</p>
            <p id="char-count" class="text-3xl font-black text-white">0</p>
        </div>
        <div class="tool-stat-card">
            <p class="tool-label mb-1">Palabras</p>
            <p id="word-count" class="text-3xl font-black text-white">0</p>
        </div>
        <div class="tool-stat-card">
            <p class="tool-label mb-1">Líneas</p>
            <p id="line-count" class="text-3xl font-black text-white">0</p>
        </div>
        <div class="tool-stat-card">
            <p class="tool-label mb-1">Bytes</p>
            <p id="byte-count" class="text-3xl font-black text-white">0</p>
        </div>
    </div>
</div>

<script>
    const input = document.getElementById('text-input') as HTMLTextAreaElement;
    const charCount = document.getElementById('char-count')!;
    const wordCount = document.getElementById('word-count')!;
    const lineCount = document.getElementById('line-count')!;
    const byteCount = document.getElementById('byte-count')!;

    function updateCounts() {
        const text = input.value;
        charCount.textContent = text.length.toLocaleString('es-ES');
        const words = text.trim().split(/\s+/).filter(Boolean);
        wordCount.textContent = text.trim() === '' ? '0' : words.length.toLocaleString('es-ES');
        lineCount.textContent = text === '' ? '0' : text.split('\n').length.toLocaleString('es-ES');
        byteCount.textContent = new TextEncoder().encode(text).length.toLocaleString('es-ES');
    }

    input.addEventListener('input', updateCounts);
    updateCounts();
</script>

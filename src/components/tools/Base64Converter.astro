---
// Base64 Converter Component
---

<div id="b64-root" class="max-w-5xl mx-auto">
    <div class="tool-panel space-y-6">
        <!-- Top bar: mode indicator + options -->
        <div class="flex flex-wrap items-center justify-between gap-4 pb-4 border-b border-white/5">
            <div class="flex items-center gap-3">
                <div id="mode-dot" class="w-2.5 h-2.5 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)] transition-all duration-300"></div>
                <span id="mode-label" class="tool-label !mb-0">Listo</span>
            </div>

            <div class="flex flex-wrap items-center gap-6">
                <div class="flex items-center gap-3">
                    <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Encoding</span>
                    <select id="text-encoding-select" class="tool-select !py-1.5 !px-3 !text-xs !bg-gray-800/50 w-32">
                        <option value="utf-8">UTF-8</option>
                        <option value="ascii">ASCII</option>
                        <option value="latin1">Latin1</option>
                    </select>
                </div>

                <div class="flex items-center gap-4">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="checkbox" id="url-safe-checkbox" class="sr-only peer">
                        <div class="w-9 h-5 bg-gray-700 rounded-full peer peer-checked:bg-blue-600 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4 relative"></div>
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider group-hover:text-gray-300 transition-colors">URL-Safe</span>
                    </label>

                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="checkbox" id="url-encoded-checkbox" class="sr-only peer">
                        <div class="w-9 h-5 bg-gray-700 rounded-full peer peer-checked:bg-blue-600 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4 relative"></div>
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider group-hover:text-gray-300 transition-colors">URL-Encode</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <div class="space-y-3">
                <div class="flex items-center justify-between">
                    <label class="tool-label !mb-0">Entrada</label>
                    <div class="flex items-center gap-4">
                        <span id="input-char-count" class="text-[10px] font-mono text-gray-500 uppercase tracking-tight">0 chars</span>
                        <button id="clear-input-btn" class="tool-btn tool-btn-ghost !py-1 !px-2 !text-[10px] uppercase tracking-wider">
                            Limpiar
                        </button>
                    </div>
                </div>
                <textarea
                    id="base64-input"
                    class="tool-textarea h-64 resize-none"
                    placeholder="Escribe o pega aquí el texto o Base64..."
                >DevcitoUtils es una colección de herramientas útiles para desarrolladores. ¡Pruébala!</textarea>
            </div>

            <div class="space-y-3">
                <div class="flex items-center justify-between">
                    <label class="tool-label !mb-0">Salida</label>
                    <div class="flex items-center gap-4">
                        <span id="output-char-count" class="text-[10px] font-mono text-gray-500 uppercase tracking-tight">0 chars</span>
                        <button id="copy-btn" class="tool-btn tool-btn-ghost !py-1 !px-2 !text-[10px] uppercase tracking-wider">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                            </svg>
                            Copiar
                        </button>
                    </div>
                </div>
                <textarea
                    id="base64-output"
                    class="tool-textarea h-64 resize-none !text-emerald-300/90 !border-emerald-500/20"
                    readonly
                    placeholder="El resultado aparecerá aquí..."
                ></textarea>
            </div>
        </div>

        <div id="error-message" class="hidden tool-error flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
            </svg>
            <span id="error-text"></span>
        </div>

        <div class="pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center gap-4">
            <button id="encode-btn" class="tool-btn tool-btn-primary flex-1 w-full">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
                </svg>
                Codificar → Base64
            </button>
            <button id="decode-btn" class="tool-btn tool-btn-success flex-1 w-full">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 15l-4 4-4-4m0-6l4-4 4 4" />
                </svg>
                Decodificar ← Base64
            </button>
        </div>
    </div>
</div>

<script>
  const input      = document.getElementById('base64-input')      as HTMLTextAreaElement;
  const output     = document.getElementById('base64-output')     as HTMLTextAreaElement;
  const encodeBtn  = document.getElementById('encode-btn')        as HTMLButtonElement;
  const decodeBtn  = document.getElementById('decode-btn')        as HTMLButtonElement;
  const copyBtn    = document.getElementById('copy-btn')          as HTMLButtonElement;
  const clearBtn   = document.getElementById('clear-input-btn')   as HTMLButtonElement;
  const urlSafeChk = document.getElementById('url-safe-checkbox') as HTMLInputElement;
  const urlEncChk  = document.getElementById('url-encoded-checkbox') as HTMLInputElement;
  const encSelect  = document.getElementById('text-encoding-select') as HTMLSelectElement;
  const errDiv     = document.getElementById('error-message')     as HTMLDivElement;
  const errText    = document.getElementById('error-text')        as HTMLSpanElement;
  const modeDot    = document.getElementById('mode-dot')          as HTMLDivElement;
  const modeLabel  = document.getElementById('mode-label')        as HTMLSpanElement;
  const inputCount = document.getElementById('input-char-count')  as HTMLDivElement;
  const outputCount= document.getElementById('output-char-count') as HTMLDivElement;

  // ── Char counters ────────────────────────────────────────────────────────────
  input.addEventListener('input', () => {
    const n = input.value.length;
    inputCount.textContent = n.toLocaleString() + ' chars';
  });

  function updateOutputCount() {
    const n = output.value.length;
    outputCount.textContent = n > 0 ? n.toLocaleString() + ' chars' : '0 chars';
  }

  // ── Mode UI helpers ──────────────────────────────────────────────────────────
  function setMode(mode: 'encoding' | 'decoding' | 'ready' | 'error') {
    const cfg: Record<string, { dot: string; label: string; dotColor: string }> = {
      encoding: { dot: 'bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.6)]',   label: 'Codificado', dotColor: 'bg-blue-500' },
      decoding: { dot: 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)]', label: 'Decodificado', dotColor: 'bg-emerald-500' },
      ready:    { dot: 'bg-gray-500 shadow-none',                      label: 'Listo', dotColor: 'bg-gray-500' },
      error:    { dot: 'bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.6)]',     label: 'Error', dotColor: 'bg-red-500' },
    };
    const c = cfg[mode];
    modeDot.className   = `w-2.5 h-2.5 rounded-full transition-all duration-300 ${c.dot}`;
    modeLabel.textContent = c.label;
  }

  // ── Error helpers ────────────────────────────────────────────────────────────
  function hideError() { errDiv.classList.add('hidden'); errText.textContent = ''; }
  function showError(msg: string) {
    errText.textContent = msg;
    errDiv.classList.remove('hidden');
    output.value = '';
    updateOutputCount();
    setMode('error');
  }

  // ── Encoding logic ───────────────────────────────────────────────────────────
  function bytesToBase64(bytes: Uint8Array) {
    let binary = '';
    for (const byte of bytes) binary += String.fromCharCode(byte);
    return btoa(binary);
  }
  function base64ToBytes(base64: string) {
    const binary = atob(base64);
    return Uint8Array.from(binary, (char) => char.charCodeAt(0));
  }
  function encodeText(text: string) {
    let bytes: Uint8Array;
    if (encSelect.value === 'utf-8') {
      bytes = new TextEncoder().encode(text);
    } else if (encSelect.value === 'ascii') {
      const arr = new Uint8Array(text.length);
      for (let i = 0; i < text.length; i++) {
        const code = text.charCodeAt(i);
        if (code > 127) throw new Error(`El caracter "${text[i]}" no es válido en ASCII.`);
        arr[i] = code;
      }
      bytes = arr;
    } else {
      const arr = new Uint8Array(text.length);
      for (let i = 0; i < text.length; i++) {
        const code = text.charCodeAt(i);
        if (code > 255) throw new Error(`El caracter "${text[i]}" no es válido en Latin1.`);
        arr[i] = code;
      }
      bytes = arr;
    }
    return bytesToBase64(bytes);
  }
  function decodeText(bytes: Uint8Array) {
    if (encSelect.value === 'utf-8') return new TextDecoder('utf-8').decode(bytes);
    if (encSelect.value === 'ascii') {
      for (const byte of bytes) {
        if (byte > 127) throw new Error('El array de bytes contiene valores fuera del rango ASCII.');
      }
    }
    return String.fromCharCode(...bytes);
  }

  // ── Button actions ───────────────────────────────────────────────────────────
  encodeBtn.addEventListener('click', () => {
    hideError();
    if (!input.value) return;
    try {
      let b64 = encodeText(input.value);
      if (urlSafeChk.checked) b64 = b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
      output.value = urlEncChk.checked ? encodeURIComponent(b64) : b64;
      updateOutputCount();
      setMode('encoding');
    } catch (e) {
      showError(e instanceof Error ? e.message : 'Error inesperado.');
    }
  });

  decodeBtn.addEventListener('click', () => {
    hideError();
    let text = input.value.trim();
    if (!text) return;
    if (urlEncChk.checked) {
      try { text = decodeURIComponent(text); }
      catch { showError('Error: la entrada no es una URL válida.'); return; }
    }
    if (/[^A-Za-z0-9\+\/=\-_]/.test(text)) {
      showError('Error: la entrada contiene caracteres inválidos para Base64 o Base64 URL-Safe.');
      return;
    }
    try {
      let norm = text.replace(/-/g, '+').replace(/_/g, '/');
      while (norm.length % 4) norm += '=';
      output.value = decodeText(base64ToBytes(norm));
      updateOutputCount();
      setMode('decoding');
    } catch {
      showError('Error: no se pudo decodificar. Revisa la cadena o el padding.');
    }
  });

  clearBtn.addEventListener('click', () => {
    input.value = ''; output.value = '';
    inputCount.textContent = '0 chars';
    updateOutputCount();
    hideError(); setMode('ready');
  });

  copyBtn.addEventListener('click', () => {
    if (!output.value) return;
    navigator.clipboard.writeText(output.value).then(() => {
      const orig = copyBtn.innerHTML;
      copyBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg> ¡Copiado!`;
      copyBtn.classList.add('!text-emerald-400');
      setTimeout(() => { copyBtn.innerHTML = orig; copyBtn.classList.remove('!text-emerald-400'); }, 2000);
    });
  });

  // Initial load
  if (input.value) {
    input.dispatchEvent(new Event('input'));
    encodeBtn.click();
  }
</script>

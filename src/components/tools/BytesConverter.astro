---
// String <-> Byte Array Converter Component
---

<div class="tool-panel max-w-4xl mx-auto space-y-5">
    <div>
        <label for="string-input" class="tool-label">Cadena de Texto</label>
        <textarea id="string-input" rows="5" class="tool-textarea" placeholder="Escribe algo..."></textarea>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label for="encoding-select" class="tool-label">Formato de texto</label>
            <select id="encoding-select" class="tool-select">
                <option value="utf-8">UTF-8</option>
                <option value="ascii">ASCII</option>
                <option value="latin1">Latin1</option>
            </select>
        </div>
        <div>
            <label for="output-format-select" class="tool-label">Formato de Bytes</label>
            <select id="output-format-select" class="tool-select">
                <option value="hex">Hexadecimal</option>
                <option value="dec">Decimal</option>
                <option value="bin">Binario</option>
            </select>
        </div>
    </div>

    <div class="flex items-center flex-wrap gap-3 py-1">
        <button id="to-bytes-btn" class="tool-btn tool-btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            Convertir a Bytes
        </button>
        <button id="to-string-btn" class="tool-btn tool-btn-success">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" /></svg>
            Convertir a Cadena
        </button>
    </div>

    <div>
        <label for="bytes-output" class="tool-label">Array de Bytes</label>
        <textarea id="bytes-output" rows="5" class="tool-textarea" placeholder="Pega aquí los bytes..."></textarea>
    </div>

    <div id="error-message" class="hidden tool-error">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" /></svg>
        <span></span>
    </div>
</div>

<script>
    const stringInput = document.getElementById('string-input') as HTMLTextAreaElement;
    const bytesOutput = document.getElementById('bytes-output') as HTMLTextAreaElement;
    const encodingSelect = document.getElementById('encoding-select') as HTMLSelectElement;
    const formatSelect = document.getElementById('output-format-select') as HTMLSelectElement;
    const toBytesBtn = document.getElementById('to-bytes-btn');
    const toStringBtn = document.getElementById('to-string-btn');
    const errorDiv = document.getElementById('error-message') as HTMLDivElement;

    function hideError() { errorDiv.classList.add('hidden'); }
    function showError(message: string) {
        errorDiv.querySelector('span')!.textContent = message;
        errorDiv.classList.remove('hidden');
    }

    function stringToBytes() {
        hideError();
        const text = stringInput.value;
        if (!text) { bytesOutput.value = ''; return; }
        let byteArray: Uint8Array | number[] = [];
        if (encodingSelect.value === 'utf-8') {
            byteArray = new TextEncoder().encode(text);
        } else if (encodingSelect.value === 'ascii') {
            const arr: number[] = [];
            for (let i = 0; i < text.length; i++) {
                const code = text.charCodeAt(i);
                if (code > 127) { showError(`El caracter "${text[i]}" no es ASCII válido.`); bytesOutput.value = ''; return; }
                arr.push(code);
            }
            byteArray = arr;
        } else {
            const arr: number[] = [];
            for (let i = 0; i < text.length; i++) {
                const code = text.charCodeAt(i);
                if (code > 255) { showError(`El caracter "${text[i]}" no es válido en Latin1.`); bytesOutput.value = ''; return; }
                arr.push(code);
            }
            byteArray = arr;
        }
        const format = formatSelect.value;
        let out = '';
        for (const byte of byteArray) {
            if (format === 'hex') out += byte.toString(16).padStart(2, '0').toUpperCase() + ' ';
            else if (format === 'dec') out += byte.toString(10) + ' ';
            else if (format === 'bin') out += byte.toString(2).padStart(8, '0') + ' ';
        }
        bytesOutput.value = out.trim();
    }

    function bytesToString() {
        hideError();
        const byteString = bytesOutput.value.trim();
        if (!byteString) { stringInput.value = ''; return; }
        const parts = byteString.split(/\s+/);
        const numbers: number[] = [];
        const radix = formatSelect.value === 'hex' ? 16 : (formatSelect.value === 'dec' ? 10 : 2);
        for (const part of parts) {
            if (!part) continue;
            const number = parseInt(part, radix);
            if (isNaN(number)) { showError(`"${part}" no es un número ${formatSelect.value} válido.`); stringInput.value = ''; return; }
            numbers.push(number);
        }
        try {
            const byteArray = new Uint8Array(numbers);
            const decoderEncoding = encodingSelect.value === 'latin1' ? 'iso-8859-1' : encodingSelect.value;
            stringInput.value = new TextDecoder(decoderEncoding, { fatal: true }).decode(byteArray);
        } catch (e) {
            showError('El array de bytes no se pudo decodificar con el formato seleccionado.');
            stringInput.value = '';
        }
    }

    toBytesBtn?.addEventListener('click', stringToBytes);
    toStringBtn?.addEventListener('click', bytesToString);
</script>
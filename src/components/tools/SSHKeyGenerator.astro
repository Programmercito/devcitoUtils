---
// SSH Key Generator Component
---

<div id="ssh-keygen-root" class="max-w-4xl mx-auto space-y-6">

    <!-- Browser Compatibility Banner -->
    <div id="compat-banner" class="hidden tool-error !bg-orange-950/20 !border-orange-500/30 !text-orange-200 flex items-start gap-4">
        <div class="flex items-start gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8.27 3H15.73a2 2 0 011.79 1.11l4.29 8.58A2 2 0 0121.8 14H2.2a2 2 0 01-.01-1.31L6.48 4.11A2 2 0 018.27 3z" />
            </svg>
            <div class="space-y-2">
                <h3 class="font-bold text-orange-300">Navegador no compatible</h3>
                <p class="text-sm opacity-90">Tu navegador no soporta la Web Crypto API necesaria para generar llaves SSH de forma segura.</p>
                <ul class="text-xs space-y-1 list-disc list-inside opacity-80">
                    <li>Usa Safari (iOS 15+), Chrome o Firefox modernos.</li>
                    <li>Asegúrate de estar bajo HTTPS.</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Error message -->
    <div id="gen-error" class="hidden tool-error flex items-start gap-3">
        <div class="flex-1">
            <p class="font-bold">Error al generar las llaves</p>
            <p id="gen-error-msg" class="text-xs font-mono opacity-80"></p>
        </div>
        <button id="gen-error-close" class="tool-btn tool-btn-ghost !p-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    <!-- Step 1 & 2 Combined -->
    <div class="tool-panel space-y-8">
        <!-- Step 1: Configuration -->
        <div class="space-y-4">
            <div class="flex items-center gap-3">
                <span class="flex items-center justify-center w-6 h-6 rounded-full bg-blue-600 text-[10px] font-bold text-white">1</span>
                <h2 class="text-sm font-bold text-white uppercase tracking-wider">Configuración</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-end">
                <div class="space-y-3">
                    <label class="tool-label !mb-0">Tamaño de la llave (bits)</label>
                    <div class="flex gap-2">
                        <button data-bits="2048" class="preset-btn tool-btn tool-btn-ghost !py-1.5 !px-3 !text-xs !bg-blue-600/10 !border-blue-500/30 !text-white">2048</button>
                        <button data-bits="4096" class="preset-btn tool-btn tool-btn-ghost !py-1.5 !px-3 !text-xs">4096</button>
                        <button data-bits="8192" class="preset-btn tool-btn tool-btn-ghost !py-1.5 !px-3 !text-xs">8192</button>
                    </div>
                </div>
                <div class="space-y-3">
                    <input id="bits-custom" type="number" min="512" max="16384" step="256" value="2048" class="tool-input" />
                    <p id="bits-warning" class="text-[10px] text-yellow-400 font-medium hidden">⚠️ Valores altos pueden demorar varios segundos.</p>
                </div>
            </div>
        </div>

        <!-- Step 2: Entropy -->
        <div class="space-y-4">
            <div class="flex items-center gap-3">
                <span class="flex items-center justify-center w-6 h-6 rounded-full bg-blue-600 text-[10px] font-bold text-white">2</span>
                <h2 class="text-sm font-bold text-white uppercase tracking-wider">Generar Entropía</h2>
            </div>
            
            <p class="text-xs text-gray-400">Mueve el cursor o desliza el dedo por el área punteada para generar aleatoriedad.</p>

            <div class="relative group">
                <canvas id="entropy-canvas" height="300" class="w-full rounded-2xl border-2 border-dashed border-white/10 bg-gray-950/40 cursor-crosshair touch-none transition-colors group-hover:border-white/20"></canvas>
                <div id="entropy-overlay" class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-600 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-6-6m0 0l6-6m-6 6h12" />
                    </svg>
                    <p id="entropy-hint" class="text-xs text-gray-500 font-medium">Mueve el mouse aquí</p>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <div class="flex-1 h-2 bg-gray-900 rounded-full overflow-hidden border border-white/5">
                    <div id="entropy-bar" class="h-full bg-gradient-to-r from-blue-600 to-cyan-500 transition-all duration-150" style="width: 0%"></div>
                </div>
                <span id="entropy-pct" class="text-xs font-mono text-gray-500 w-10">0%</span>
                <button id="clear-canvas-btn" class="tool-btn tool-btn-ghost !py-1 !px-2 !text-[10px]">Reiniciar</button>
            </div>
        </div>

        <!-- Action Button -->
        <div class="pt-6 border-t border-white/5 flex justify-center">
            <button id="generate-btn" disabled class="tool-btn tool-btn-primary w-full sm:w-auto min-w-[240px] disabled:opacity-50 disabled:cursor-not-allowed">
                <svg id="gen-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H5v-2H3v-2H1v-4a6 6 0 017.743-5.743z" />
                </svg>
                <span id="gen-label">Falta Entropía</span>
            </button>
        </div>
    </div>

    <!-- Spinner -->
    <div id="gen-spinner" class="hidden flex-col items-center gap-3 py-12">
        <div class="w-12 h-12 border-4 border-blue-500/20 border-t-blue-500 rounded-full animate-spin"></div>
        <p class="text-sm font-medium text-gray-400">Generando llaves RSA...</p>
    </div>

    <!-- Step 3: Output -->
    <div id="output-section" class="hidden space-y-6">
        <div class="tool-panel space-y-4 !border-emerald-500/20">
            <div class="flex items-center justify-between">
                <label class="tool-label !mb-0 !text-emerald-400">Llave Privada (id_rsa)</label>
                <div class="flex gap-2">
                    <button id="copy-private" class="tool-btn tool-btn-ghost !py-1 !px-3 !text-[10px]">Copiar</button>
                    <button id="download-private" class="tool-btn tool-btn-success !py-1 !px-3 !text-[10px]">Descargar</button>
                </div>
            </div>
            <textarea id="private-key-out" rows="8" readonly class="tool-textarea !text-emerald-300/90 !bg-emerald-500/5 !border-emerald-500/10 text-xs"></textarea>
            <p class="text-[10px] text-emerald-500/60 font-medium">⚠️ Nunca compartas tu llave privada. Guárdala en un lugar seguro.</p>
        </div>

        <div class="tool-panel space-y-6 !border-blue-500/20">
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <label class="tool-label !mb-0 !text-blue-400">Llave Pública OpenSSH</label>
                    <div class="flex gap-2">
                        <button id="copy-public-ssh" class="tool-btn tool-btn-ghost !py-1 !px-3 !text-[10px]">Copiar</button>
                        <button id="download-public-ssh" class="tool-btn tool-btn-primary !py-1 !px-3 !text-[10px]">Descargar</button>
                    </div>
                </div>
                <textarea id="public-key-ssh-out" rows="3" readonly class="tool-textarea !text-blue-300/90 !bg-blue-500/5 !border-blue-500/10 text-xs"></textarea>
            </div>

            <div class="space-y-4 pt-6 border-t border-white/5">
                <div class="flex items-center justify-between">
                    <label class="tool-label !mb-0 !text-cyan-400">Llave Pública PEM</label>
                    <div class="flex gap-2">
                        <button id="copy-public" class="tool-btn tool-btn-ghost !py-1 !px-3 !text-[10px]">Copiar</button>
                        <button id="download-public-pem" class="tool-btn tool-btn-ghost !py-1 !px-3 !text-[10px] !bg-cyan-500/10 !text-cyan-300">Descargar</button>
                    </div>
                </div>
                <textarea id="public-key-out" rows="6" readonly class="tool-textarea !text-cyan-300/90 !bg-cyan-500/5 !border-cyan-500/10 text-xs"></textarea>
            </div>
        </div>

        <div class="flex justify-center">
            <button id="reset-btn" class="tool-btn tool-btn-ghost group">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-400 group-hover:rotate-180 transition-transform duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Generar de Nuevo
            </button>
        </div>
    </div>
</div>

<script>
// ─── Entropy Canvas ───────────────────────────────────────────────────────────
const canvas = document.getElementById('entropy-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const entropyBar = document.getElementById('entropy-bar') as HTMLDivElement;
const entropyPct = document.getElementById('entropy-pct') as HTMLSpanElement;
const entropyStatus = document.getElementById('entropy-status');
const entropyHint = document.getElementById('entropy-hint') as HTMLParagraphElement;
const entropyOverlay = document.getElementById('entropy-overlay') as HTMLDivElement;
const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
const genLabel = document.getElementById('gen-label') as HTMLSpanElement;
const bitsInput = document.getElementById('bits-custom') as HTMLInputElement;
const bitsWarning = document.getElementById('bits-warning') as HTMLParagraphElement;
const outputSection = document.getElementById('output-section') as HTMLDivElement;
const genSpinner = document.getElementById('gen-spinner') as HTMLDivElement;
const privateKeyOut = document.getElementById('private-key-out') as HTMLTextAreaElement;
const publicKeyOut = document.getElementById('public-key-out') as HTMLTextAreaElement;
const publicKeySshOut = document.getElementById('public-key-ssh-out') as HTMLTextAreaElement;
const compatBanner = document.getElementById('compat-banner') as HTMLDivElement;
const genError = document.getElementById('gen-error') as HTMLDivElement;
const genErrorMsg = document.getElementById('gen-error-msg') as HTMLParagraphElement;

// ─── Browser compatibility check ─────────────────────────────────────────────
const cryptoAvailable = typeof window !== 'undefined'
  && window.crypto != null
  && window.crypto.subtle != null
  && typeof window.crypto.subtle.generateKey === 'function';

if (!cryptoAvailable) {
  compatBanner?.classList.remove('hidden');
  generateBtn.disabled = true;
}

// Close error banner
document.getElementById('gen-error-close')?.addEventListener('click', () => {
  genError.classList.add('hidden');
});

const ENTROPY_GOAL = 600;
let entropyPoints: number[] = [];
let lastX = -1, lastY = -1;
let isCollecting = true;

function resizeCanvas() {
  const rect = canvas.getBoundingClientRect();
  canvas.width = rect.width;
  canvas.height = 300;
}
requestAnimationFrame(() => { resizeCanvas(); });
window.addEventListener('resize', resizeCanvas);

function getPos(e: MouseEvent | TouchEvent): {x: number, y: number} {
  const rect = canvas.getBoundingClientRect();
  if (e instanceof TouchEvent) {
    const t = e.touches[0];
    return { x: t.clientX - rect.left, y: t.clientY - rect.top };
  }
  return { x: (e as MouseEvent).clientX - rect.left, y: (e as MouseEvent).clientY - rect.top };
}

function onMove(e: MouseEvent | TouchEvent) {
  if (!isCollecting) return;
  e.preventDefault();
  const { x, y } = getPos(e);

  const t = performance.now();
  entropyPoints.push(x, y, t);

  ctx.beginPath();
  if (lastX !== -1) {
    ctx.moveTo(lastX, lastY);
    ctx.lineTo(x, y);
    const hue = (entropyPoints.length / 3) * 3 % 360;
    ctx.strokeStyle = `hsl(${hue}, 80%, 65%)`;
    ctx.lineWidth = 3;
    ctx.lineCap = 'round';
    ctx.stroke();
  }
  lastX = x; lastY = y;

  const pts = Math.min(entropyPoints.length / 3, ENTROPY_GOAL);
  const pct = Math.round((pts / ENTROPY_GOAL) * 100);
  entropyBar.style.width = pct + '%';
  entropyPct.textContent = pct + '%';

  if (pts >= ENTROPY_GOAL) {
    isCollecting = false;
    entropyOverlay.classList.add('hidden');
    if (generateBtn) {
      generateBtn.disabled = false;
      genLabel.textContent = 'Generar Llaves SSH';
    }
  } else {
    entropyHint.textContent = `${Math.round(pts)} / ${ENTROPY_GOAL} puntos`;
  }
}

canvas.addEventListener('mousemove', onMove);
canvas.addEventListener('touchmove', onMove, { passive: false });

// ─── Key size presets ─────────────────────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('.preset-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const bits = parseInt(btn.dataset.bits!);
    bitsInput.value = String(bits);
    document.querySelectorAll('.preset-btn').forEach(b => {
      b.classList.remove('!bg-blue-600/10', '!border-blue-500/30', '!text-white');
    });
    btn.classList.add('!bg-blue-600/10', '!border-blue-500/30', '!text-white');
    bitsWarning.classList.toggle('hidden', bits <= 4096);
  });
});

bitsInput.addEventListener('input', () => {
  const v = parseInt(bitsInput.value);
  bitsWarning.classList.toggle('hidden', v <= 4096);
  document.querySelectorAll('.preset-btn').forEach(b => {
    b.classList.remove('!bg-blue-600/10', '!border-blue-500/30', '!text-white');
  });
});

// ─── RSA Generation logic ────────────────────────────────────────────────────
async function generateRSAKeys(bits: number): Promise<{ privatePem: string, publicPem: string, publicOpenSsh: string }> {
  const keyPair = await window.crypto.subtle.generateKey(
    {
      name: 'RSASSA-PKCS1-v1_5',
      modulusLength: bits,
      publicExponent: new Uint8Array([1, 0, 1]),
      hash: 'SHA-256',
    },
    true,
    ['sign', 'verify']
  );

  const [privDer, pubDer] = await Promise.all([
    crypto.subtle.exportKey('pkcs8', keyPair.privateKey),
    crypto.subtle.exportKey('spki', keyPair.publicKey),
  ]);

  return {
    privatePem: toPem(privDer, 'PRIVATE KEY'),
    publicPem: toPem(pubDer, 'PUBLIC KEY'),
    publicOpenSsh: toOpenSSHPublicKey(pubDer),
  };
}

function toPem(der: ArrayBuffer, label: string): string {
  const b64 = btoa(String.fromCharCode(...new Uint8Array(der)));
  const lines = b64.match(/.{1,64}/g)!.join('\n');
  return `-----BEGIN ${label}-----\n${lines}\n-----END ${label}-----\n`;
}

function toOpenSSHPublicKey(spki: ArrayBuffer): string {
  const bytes = new Uint8Array(spki);
  const { n, e } = extractRsaParamsFromSpki(bytes);
  const keyType = 'ssh-rsa';
  const typeBytes = encodeString(new TextEncoder().encode(keyType));
  const eBytes = encodeMpint(e);
  const nBytes = encodeMpint(n);
  const payload = new Uint8Array(typeBytes.length + eBytes.length + nBytes.length);
  payload.set(typeBytes, 0);
  payload.set(eBytes, typeBytes.length);
  payload.set(nBytes, typeBytes.length + eBytes.length);
  const b64 = btoa(String.fromCharCode(...payload));
  return `ssh-rsa ${b64} devcito-utils-generated\n`;
}

function encodeString(bytes: Uint8Array): Uint8Array {
  const len = new Uint8Array(4);
  new DataView(len.buffer).setUint32(0, bytes.length, false);
  const result = new Uint8Array(4 + bytes.length);
  result.set(len); result.set(bytes, 4);
  return result;
}

function encodeMpint(bytes: Uint8Array): Uint8Array {
  let start = 0;
  while (start < bytes.length - 1 && bytes[start] === 0) start++;
  let data = bytes.slice(start);
  if (data[0] & 0x80) {
    const padded = new Uint8Array(data.length + 1);
    padded.set(data, 1); data = padded;
  }
  return encodeString(data);
}

function extractRsaParamsFromSpki(bytes: Uint8Array): { n: Uint8Array, e: Uint8Array } {
  let pos = 0;
  const readLen = (buf: Uint8Array, p: number): { len: number, advance: number } => {
    if (buf[p] < 0x80) return { len: buf[p], advance: 1 };
    const numBytes = buf[p] & 0x7f;
    let len = 0;
    for (let i = 0; i < numBytes; i++) len = (len << 8) | buf[p + 1 + i];
    return { len, advance: 1 + numBytes };
  };
  pos++; let { advance } = readLen(bytes, pos); pos += advance;
  pos++; let r2 = readLen(bytes, pos); pos += r2.advance; pos += r2.len;
  pos++; let r3 = readLen(bytes, pos); pos += r3.advance; pos++;
  pos++; let r4 = readLen(bytes, pos); pos += r4.advance;
  pos++; let rn = readLen(bytes, pos); pos += rn.advance;
  const n = bytes.slice(pos, pos + rn.len); pos += rn.len;
  pos++; let re = readLen(bytes, pos); pos += re.advance;
  const e = bytes.slice(pos, pos + re.len);
  return { n, e };
}

// ─── Generate button ──────────────────────────────────────────────────────────
generateBtn.addEventListener('click', async () => {
  let bits = parseInt(bitsInput.value);
  if (isNaN(bits) || bits < 512) bits = 2048;
  if (bits % 256 !== 0) bits = Math.round(bits / 256) * 256;

  generateBtn.parentElement!.classList.add('hidden');
  genSpinner.classList.remove('hidden');
  outputSection.classList.add('hidden');

  try {
    await new Promise(r => setTimeout(r, 100));
    const { privatePem, publicPem, publicOpenSsh } = await generateRSAKeys(bits);
    privateKeyOut.value = privatePem;
    publicKeyOut.value = publicPem;
    publicKeySshOut.value = publicOpenSsh;
    outputSection.classList.remove('hidden');
    genError.classList.add('hidden');
  } catch (err) {
    genErrorMsg.textContent = String(err);
    genError.classList.remove('hidden');
    generateBtn.parentElement!.classList.remove('hidden');
  } finally {
    genSpinner.classList.add('hidden');
  }
});

// ─── Copy & Download ──────────────────────────────────────────────────────────
function setupButtons(btnId: string, srcId: string, filename?: string) {
  const btn = document.getElementById(btnId)!;
  const src = document.getElementById(srcId) as HTMLTextAreaElement;
  btn.addEventListener('click', () => {
    if (filename) {
      const blob = new Blob([src.value], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = filename; a.click();
      URL.revokeObjectURL(url);
    } else {
      navigator.clipboard.writeText(src.value).then(() => {
        const orig = btn.innerHTML;
        btn.innerHTML = '¡Copiado!';
        btn.classList.add('!text-emerald-400');
        setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('!text-emerald-400'); }, 2000);
      });
    }
  });
}

setupButtons('copy-private', 'private-key-out');
setupButtons('download-private', 'private-key-out', 'id_rsa');
setupButtons('copy-public-ssh', 'public-key-ssh-out');
setupButtons('download-public-ssh', 'public-key-ssh-out', 'id_rsa.pub');
setupButtons('copy-public', 'public-key-out');
setupButtons('download-public-pem', 'public-key-out', 'id_rsa_pub.pem');

// ─── Reset & Clear ────────────────────────────────────────────────────────────
function clearEntropy() {
  entropyPoints = []; lastX = -1; lastY = -1; isCollecting = true;
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  entropyBar.style.width = '0%'; entropyPct.textContent = '0%';
  entropyHint.textContent = 'Mueve el mouse aquí';
  entropyOverlay.classList.remove('hidden');
  generateBtn.disabled = true; genLabel.textContent = 'Falta Entropía';
  generateBtn.parentElement!.classList.remove('hidden');
}

document.getElementById('clear-canvas-btn')?.addEventListener('click', clearEntropy);
document.getElementById('reset-btn')?.addEventListener('click', () => {
  clearEntropy();
  outputSection.classList.add('hidden');
  window.scrollTo({ top: 0, behavior: 'smooth' });
});
</script>
